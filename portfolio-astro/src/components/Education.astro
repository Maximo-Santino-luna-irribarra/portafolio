<section id="educacion" class="bg-zinc-900/30">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-12 flex items-center gap-2">
      <span class="text-cyan-500">03.</span> Educación
    </h2>

    <div class="grid gap-8">
      <!-- UTN -->
      <div class="p-6 rounded-xl border border-zinc-800 bg-zinc-900/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h3 class="text-xl font-bold text-white">Tecnicatura Universitaria en Programación</h3>
          <p class="text-cyan-500 font-medium">Universidad Tecnológica Nacional (UTN)</p>
        </div>
        <div class="text-right">
          <span class="px-3 py-1 bg-zinc-800 text-zinc-400 text-sm rounded-full border border-zinc-700">2024 - 2025</span>
        </div>
      </div>

      <!-- Secundaria -->
      <div class="p-6 rounded-xl border border-zinc-800 bg-zinc-900/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h3 class="text-xl font-bold text-white">Bachiller en Ciencias Sociales</h3>
          <p class="text-cyan-500 font-medium">Escuela Secundaria El Encuentro</p>
        </div>
        <div class="text-right">
          <span class="px-3 py-1 bg-zinc-800 text-zinc-400 text-sm rounded-full border border-zinc-700">2016 - 2024</span>
        </div>
      </div>
    </div>
  </div>
