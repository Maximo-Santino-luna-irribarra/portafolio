<section id="contacto">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">¿Hablamos?</h2>
      <p class="text-zinc-500">Estoy disponible para nuevas oportunidades y proyectos.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-8">
        <h3 class="text-2xl font-bold text-white">Información de Contacto</h3>
        
        <div class="space-y-6">
          <a href="mailto:lunamaximosantino@gmail.com" class="flex items-center gap-4 group">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-lg group-hover:border-cyan-500/50 transition-colors">
              <svg class="w-6 h-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-zinc-500">Email</p>
              <p class="text-zinc-200">lunamaximosantino@gmail.com</p>
            </div>
          </a>

          <a href="tel:+5491141795357" class="flex items-center gap-4 group">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-lg group-hover:border-cyan-500/50 transition-colors">
              <svg class="w-6 h-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-zinc-500">Teléfono</p>
              <p class="text-zinc-200">+54 9 11 4179-5357</p>
            </div>
          </a>

          <div class="flex items-center gap-4 group">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-lg">
              <svg class="w-6 h-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-zinc-500">Ubicación</p>
              <p class="text-zinc-200">Monte Grande, Buenos Aires</p>
            </div>
          </div>
        </div>

        <div class="pt-6">
          <a 
            href="https://wa.me/5491141795357" 
            target="_blank"
            class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-500 text-white font-bold rounded-lg transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.246 2.248 3.484 5.232 3.484 8.412-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.956-.5-5.705-1.448l-6.305 1.656zm6.373-4.035c1.584.939 3.129 1.417 4.888 1.418 5.231 0 9.487-4.258 9.489-9.489.002-5.231-4.256-9.49-9.488-9.49-5.231 0-9.489 4.259-9.489 9.49 0 1.842.531 3.591 1.541 5.099l-.987 3.605 3.697-.97c.01.001.011-.001.01-.001-.01 0-.01-.01-.01-.01zm10.867-6.931c-.161-.269-.591-.43-.161-.43-.431-.215-1.829-.902-2.112-1.004-.282-.102-.489-.153-.694.153-.205.307-.795 1.004-.974 1.208-.18.204-.359.23-.79.016-.431-.214-1.82-.672-3.466-2.14-1.281-1.142-2.145-2.552-2.396-2.982-.251-.431-.027-.664.188-.878.194-.193.43-.501.646-.752.215-.252.287-.431.43-.717.143-.287.072-.538-.036-.753-.107-.214-.694-1.673-.951-2.292-.25-.606-.503-.524-.694-.534-.18-.01-.384-.012-.591-.012s-.538.077-.82.384c-.282.308-1.077 1.05-1.077 2.561s1.102 2.971 1.255 3.176c.154.204 2.169 3.311 5.255 4.643.734.317 1.307.507 1.754.65.737.234 1.408.201 1.939.122.591-.088 1.829-.747 2.086-1.469.256-.723.256-1.343.18-1.469z"/></svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>

      <!-- Form Placeholder -->
      <div class="p-8 rounded-2xl bg-zinc-900 border border-zinc-800">
        <form class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-1">Nombre</label>
            <input type="text" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-cyan-500 transition-colors" placeholder="Tu nombre" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-1">Email</label>
            <input type="email" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-cyan-500 transition-colors" placeholder="tu@email.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-1">Mensaje</label>
            <textarea rows="4" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-cyan-500 transition-colors" placeholder="¿En qué puedo ayudarte?"></textarea>
          </div>
          <button type="button" class="w-full py-3 bg-zinc-100 text-zinc-900 font-bold rounded-lg hover:bg-white transition-colors">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
