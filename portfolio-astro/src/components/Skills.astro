---
import { skillGroups } from '../data/skills';
---

<section id="habilidades" class="bg-black py-24">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Habilidades Técnicas</h2>
      <div class="h-1.5 w-24 bg-gradient-to-r from-cyan-500 to-blue-600 mx-auto rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {skillGroups.map((group) => (
        <div class="space-y-6">
          <h3 class="text-xl font-bold text-zinc-500 uppercase tracking-widest text-xs border-b border-zinc-800 pb-2">
            {group.category}
          </h3>
          <div class="grid grid-cols-1 gap-3">
            {group.skills.map((skill) => (
              <div 
                class="flex flex-col p-3 rounded-xl bg-zinc-900/40 border border-zinc-800/50 hover:border-transparent transition-all duration-300 group relative overflow-hidden"
                style={`--skill-color: ${skill.color}`}
              >
                <!-- Glow Effect background -->
                <div 
                  class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-300"
                  style={`background-color: ${skill.color}`}
                ></div>
                
                <div class="flex items-center gap-3 z-10">
                  <div 
                    class="w-10 h-10 flex items-center justify-center rounded-lg bg-zinc-800/50 group-hover:scale-110 transition-transform duration-300 shadow-inner"
                    style={`border: 1px solid ${skill.color}33`}
                  >
                    <img 
                      src={`/src/assets/svgs/${skill.icon}.svg`} 
                      alt={skill.name}
                      class="w-6 h-6 object-contain transition-all duration-300 group-hover:scale-110"
                    />
                  </div>
                  
                  <span class="font-medium text-zinc-300 group-hover:text-white transition-colors">
                    {skill.name}
                  </span>
                </div>

                <!-- Description (Hidden by default, shown on hover) -->
                <div class="max-h-0 opacity-0 group-hover:max-h-24 group-hover:opacity-100 group-hover:mt-3 transition-all duration-500 ease-in-out z-10">
                  <p class="text-xs text-zinc-400 leading-relaxed">
                    {skill.description}
                  </p>
                </div>

                <!-- Subtle border glow line at bottom -->
                <div 
                  class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[var(--skill-color)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                ></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .group:hover {
    box-shadow: 0 10px 30px -10px var(--skill-color);
    background-color: rgba(20, 20, 20, 0.9);
  }
</style>
